---
import type { CollectionEntry } from "astro:content";
import path from "node:path";
import ImageWrapper from "@components/misc/ImageWrapper.astro";
import { formatDateToYYYYMMDD } from "@utils/date-utils";
import { getDir, getPostUrlBySlug } from "@utils/url-utils";
import { Icon } from "astro-icon/components";

interface Props {
	posts: CollectionEntry<"posts">[];
}

const { posts } = Astro.props;
---

{posts.length > 0 && (
	<section class="related-posts onload-animation mb-6">
		<div class="flex items-center gap-2 mb-3 px-1">
			<div class="meta-icon !mr-0">
				<Icon name="material-symbols:auto-stories-outline-rounded" class="text-xl" />
			</div>
			<h2 class="text-90 font-bold text-xl">Bài viết liên quan</h2>
		</div>
		<div class="grid md:grid-cols-3 gap-3">
			{posts.map((post) => {
				const hasCover = !!post.data.image;
				return (
					<a
						data-related-post
						href={getPostUrlBySlug(post.slug)}
						class="related-card card-base interactive-card group block overflow-hidden"
						aria-label={post.data.title}
					>
						<div class="relative h-32 overflow-hidden bg-[var(--btn-regular-bg)]">
							{hasCover ? (
								<ImageWrapper
									src={post.data.image}
									basePath={path.join("content/posts/", getDir(post.id))}
									alt={post.data.title}
									class="w-full h-full banner-container"
								/>
							) : (
								<div class="w-full h-full related-gradient"></div>
							)}
							<div class="absolute inset-0 bg-gradient-to-t from-black/55 via-black/10 to-transparent"></div>
							<Icon
								name="material-symbols:arrow-forward-rounded"
								class="absolute right-3 bottom-3 text-white text-2xl opacity-0 -translate-x-2 group-hover:opacity-100 group-hover:translate-x-0 transition"
							/>
						</div>
						<div class="p-4">
							<div class="text-90 font-bold line-clamp-2 group-hover:text-[var(--primary)]">
								{post.data.title}
							</div>
							<div class="text-30 text-sm mt-2 flex items-center gap-2">
								<Icon name="material-symbols:calendar-today-outline-rounded" />
								<span>{formatDateToYYYYMMDD(post.data.published)}</span>
							</div>
						</div>
					</a>
				);
			})}
		</div>
	</section>
)}

<style>
	.related-gradient {
		background:
			radial-gradient(circle at 20% 20%, color-mix(in oklch, var(--primary), white 35%), transparent 36%),
			linear-gradient(135deg, var(--btn-regular-bg), var(--page-bg));
	}
</style>
