---
import path from "node:path";

interface Props {
	id?: string;
	src: string;
	class?: string;
	alt?: string;
	position?: string;
	basePath?: string;
}

import { Image } from "astro:assets";
import { url } from "../../utils/url-utils";

const { id, src, alt, position = "center", basePath = "/" } = Astro.props;
const className = Astro.props.class;

const isLocal = !(
	src.startsWith("/") ||
	src.startsWith("http") ||
	src.startsWith("https") ||
	src.startsWith("data:")
);
const isPublic = src.startsWith("/");

// TODO temporary workaround for images dynamic import
// https://github.com/withastro/astro/issues/3373
let img: ImageMetadata | undefined;
if (isLocal) {
	const files = import.meta.glob<ImageMetadata>("../../**", {
		import: "default",
	});
	let normalizedPath = path
		.normalize(path.join("../../", basePath, src))
		.replace(/\\/g, "/");
	const file = files[normalizedPath];
	if (!file) {
		console.error(
			`\n[ERROR] Image file not found: ${normalizedPath.replace("../../", "src/")}`,
		);
	}
	img = await file();
}

const imageClass = "w-full h-full object-cover";
const imageStyle = `object-position: ${position}`;
const loading = id === "banner" ? "eager" : "lazy";
---
<div id={id} class:list={[className, 'overflow-hidden relative image-wrapper']}>
    <div class="image-soft-overlay transition absolute inset-0 pointer-events-none"></div>
    {isLocal && img && <Image src={img} alt={alt || ""} class={imageClass} style={imageStyle} loading={loading} decoding="async"/>}
    {!isLocal && <img src={isPublic ? url(src) : src} alt={alt || ""} class={imageClass} style={imageStyle} loading={loading} decoding="async"/>}
</div>

<style>
    .image-soft-overlay {
        z-index: 1;
        background:
            linear-gradient(to top, rgb(0 0 0 / 0.10), transparent 45%),
            linear-gradient(to bottom, rgb(255 255 255 / 0.04), transparent 35%);
    }

    :global(.dark) .image-soft-overlay {
        background:
            linear-gradient(to top, rgb(0 0 0 / 0.28), transparent 52%),
            linear-gradient(to bottom, rgb(255 255 255 / 0.03), transparent 35%);
    }
</style>
